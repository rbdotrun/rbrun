<div id="<%= "turn_#{user_message.id}" %>" class="flex flex-col gap-4">
  <div class="max-w-[66.6667%] self-end whitespace-pre-wrap rounded-lg bg-slate-50 px-4 py-2.5 text-sm text-slate-800">
    <%= user_message.content %>
  </div>

  <div class="flex flex-col gap-3">
    <span class="flex size-7 shrink-0 items-center justify-center self-start rounded-md bg-default-50 text-default-600">
      <%= lucide_icon("sparkles", class: "size-4") %>
    </span>

    <div id="<%= "timeline_#{user_message.id}" %>" class="flex flex-col gap-3 text-sm">
      <%= render(Rbrun::Sessions::Timeline::Component.new(messages: messages, working: working)) %>
    </div>

    <%# The turn footer — only once the turn is done and actually produced a response. %>
    <% if !working && messages.any? { |m| m.role == "assistant" } %>
      <%= custom("sessions/turn_footer", user_message: user_message) %>
    <% end %>
  </div>
</div>
