<% commits = session.worktree.commits.order(created_at: :desc).limit(20) %>
<% if commits.any? %>
  <div class="my-4 rounded-lg border border-slate-200 bg-slate-50 p-3">
    <p class="mb-2 flex items-center gap-1.5 text-xs font-semibold text-slate-500">
      <%= lucide_icon("git-commit-horizontal", class: "size-3.5") %>
      <%= helpers.pluralize(commits.size, "commit") %> on <%= session.worktree.branch %>
    </p>
    <ul class="flex flex-col gap-1 text-xs">
      <% commits.each do |c| %>
        <li class="flex items-center gap-2">
          <code class="shrink-0 text-slate-400"><%= c.sha[0, 7] %></code>
          <span class="truncate text-slate-600"><%= c.message %></span>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
