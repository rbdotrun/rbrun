<div class="border-t border-slate-200 p-3">
  <% if answered? %>
    <p class="mb-1 text-xs font-medium text-slate-500">Your answer</p>
    <ul class="flex flex-col gap-0.5 text-sm text-slate-700">
      <% answers.each do |key, vals| %>
        <li>
          <span class="text-slate-400"><%= spec.question(key)&.dig("label") || key %>:</span>
          <%= Array(vals).map { |v| spec.label_for(key, v) }.join(", ") %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <%= form_with url: submit_path, method: :post, class: "flex flex-col gap-3" do %>
      <% if spec.title.present? %>
        <p class="text-sm font-medium text-slate-800"><%= spec.title %></p>
      <% end %>
      <% spec.steps.each do |step| %>
        <% Array(step["questions"]).each do |q| %>
          <fieldset class="flex flex-col gap-1.5">
            <legend class="text-xs font-medium text-slate-600"><%= q["label"] %></legend>
            <% Array(q["options"]).each do |opt| %>
              <label class="flex items-center gap-2 text-sm text-slate-700">
                <input type="<%= spec.multiple?(q["key"]) ? "checkbox" : "radio" %>" name="<%= field_name(q) %>"
                       value="<%= opt["value"] %>" <%= "required" if q["required"] && !spec.multiple?(q["key"]) %>
                       class="size-3.5 accent-default-600">
                <%= opt["label"] %>
              </label>
            <% end %>
          </fieldset>
        <% end %>
      <% end %>
      <div class="flex items-center gap-2 pt-1">
        <%= component("button", variant: :primary, size: :sm, type: "submit") do %>Submit<% end %>
        <span class="ml-auto text-[11px] text-slate-400">Or ask for a change in the conversation.</span>
      </div>
    <% end %>
  <% end %>
</div>
