<div class="border-t border-slate-200 p-3">
  <p class="mb-1 text-xs font-medium text-slate-500">Start services?</p>
  <ul class="mb-3 flex flex-col gap-1 text-sm">
    <% services.each do |svc| %>
      <li class="flex items-baseline gap-2">
        <span class="font-medium text-slate-800"><%= svc["name"] %></span>
        <% if svc["port"].present? %><span class="text-xs text-slate-400">:<%= svc["port"] %></span><% end %>
        <code class="ml-auto truncate text-xs text-slate-500"><%= svc["command"] %></code>
      </li>
    <% end %>
  </ul>
  <% if decided? %>
    <p class="text-sm text-slate-700"><%= approved? ? "Started." : "Not started." %></p>
  <% else %>
    <div class="flex items-center gap-2 pt-1">
      <%= approval_actions(tool_use_id) %>
      <span class="ml-auto text-[11px] text-slate-400">Or ask for a change in the conversation.</span>
    </div>
  <% end %>
</div>
