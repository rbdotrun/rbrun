<div class="border-t border-slate-200 p-3">
  <div class="mb-2 flex items-start gap-2 rounded-md border border-amber-300 bg-amber-50 px-2.5 py-2">
    <%= lucide_icon("globe", class: "size-4 shrink-0 translate-y-0.5 text-amber-600") %>
    <div class="text-sm">
      <p class="font-medium text-amber-900">Make “<%= service_name %>” public?</p>
      <p class="text-xs text-amber-800">
        Anyone with the link will be able to open it — <strong>no account required</strong>. Only this one
        service is exposed; the sandbox itself stays private. You can revoke it at any time.
      </p>
    </div>
  </div>
  <% if decided? %>
    <% if approved? && public_url.present? %>
      <p class="text-xs font-medium text-slate-500">Public link</p>
      <code class="block truncate rounded bg-slate-50 px-2 py-1 text-xs text-slate-700"><%= public_url %></code>
    <% else %>
      <p class="text-sm text-slate-700"><%= approved? ? "Shared publicly." : "Not shared — it stays private." %></p>
    <% end %>
  <% else %>
    <div class="flex items-center gap-2 pt-1">
      <%= approval_actions(tool_use_id) %>
      <span class="ml-auto text-[11px] text-slate-400">Refuse to keep it private.</span>
    </div>
  <% end %>
</div>
