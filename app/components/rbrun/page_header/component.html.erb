<%# The header row of a page card — or of its side panel. Same bar, same divider, wherever it sits. %>
<header class="flex h-16 flex-shrink-0 items-center justify-between gap-4 border-b border-slate-200 px-6">
  <div class="flex min-w-0 items-center gap-3">
    <% if back.present? %>
      <%= link_to back, class: "text-slate-500 hover:text-slate-700", "aria-label": "Back" do %>
        <%= lucide_icon("arrow-left", class: "size-4") %>
      <% end %>
    <% end %>
    <% if title.present? %>
      <h1 class="truncate text-xl font-semibold text-slate-800"><%= title %></h1>
    <% end %>
  </div>

  <%# Whatever the caller passes: a switch, a button, a tab strip. %>
  <% if content.present? %>
    <div class="flex flex-shrink-0 items-center gap-2"><%= content %></div>
  <% end %>
</header>
