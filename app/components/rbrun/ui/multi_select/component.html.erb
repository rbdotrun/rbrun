<% if grouped %>
  <%# Grouped catalog: parent sub-headings + a search that hides empty groups. %>
  <fieldset class="flex flex-col gap-1.5" data-controller="option-filter">
    <legend class="text-sm font-medium text-slate-700"><%= label %></legend>
    <input type="hidden" name="<%= name %>[]" value="" autocomplete="off">
    <% if searchable? %>
      <%= component("input", size: :sm, name: nil, placeholder: "Search…", autocomplete: "off",
            "aria-label": "Filter #{label}",
            data: { option_filter_target: "input", action: "input->option-filter#filter" }) %>
    <% end %>
    <div class="flex max-h-80 flex-col gap-1 overflow-y-auto rounded-md border border-slate-200 p-2">
      <% groups.each do |group_label, items| %>
        <div data-option-filter-target="group" class="flex flex-col gap-1">
          <% if group_label %>
            <p class="px-1 pt-2 text-xs font-semibold uppercase tracking-wide text-slate-400"><%= group_label %></p>
          <% end %>
          <% items.each do |opt_label, opt_value| %>
            <label data-option-filter-target="option"
                   class="flex cursor-pointer items-center gap-2 rounded-md px-1 py-1 text-sm text-slate-700 hover:bg-slate-50">
              <%= component("checkbox", name: "#{name}[]", value: opt_value, checked: selected?(opt_value)) %>
              <span><%= opt_label %></span>
            </label>
          <% end %>
        </div>
      <% end %>
    </div>
  </fieldset>
<% else %>
  <%# Flat list — the 2-col grid. %>
  <fieldset class="flex flex-col gap-1.5">
    <legend class="text-sm font-medium text-slate-700"><%= label %></legend>
    <input type="hidden" name="<%= name %>[]" value="" autocomplete="off">
    <div class="grid grid-cols-2 gap-2">
      <% options.each do |opt_label, opt_value| %>
        <label class="flex items-center gap-2 text-sm text-slate-700">
          <input type="checkbox" name="<%= name %>[]" value="<%= opt_value %>"
                 <%= "checked" if selected?(opt_value) %> class="rounded border-slate-300">
          <%= opt_label %>
        </label>
      <% end %>
    </div>
  </fieldset>
<% end %>
