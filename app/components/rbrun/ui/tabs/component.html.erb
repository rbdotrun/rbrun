<nav class="flex items-center gap-1 border-b border-slate-200 px-6" aria-label="<%= @label %>">
  <% @tabs.each do |t| %>
    <%= link_to t[:href], data: { tab: t[:key] }, "aria-current": (t[:active] ? "page" : nil),
          class: class_names(
            "relative -mb-px border-b-2 px-3 py-2.5 text-sm font-medium transition-colors",
            ("border-default-600 text-default-700" if t[:active]),
            ("border-transparent text-slate-500 hover:text-slate-800" unless t[:active])) do %>
      <%= t[:label] %>
      <% if t[:count] %>
        <span data-tab-count="<%= t[:count] %>" class="<%= class_names(
              "ml-1.5 inline-flex min-w-5 items-center justify-center rounded-full px-1.5 py-0.5 text-[11px] font-medium tabular-nums",
              ("bg-default-50 text-default-700" if t[:active]),
              ("bg-slate-100 text-slate-500" unless t[:active])) %>"><%= badge_count(t[:count]) %></span>
      <% end %>
    <% end %>
  <% end %>
</nav>
