<div class="<%= class_names(wrapper_classes, @attrs.delete(:class)) %>" <%= tag.attributes(@attrs) %>>
  <% unless headless? %>
    <%# flush: pinned via absolute (never scrolls away); the rows reserve HEADER_H of space. %>
    <div class="<%= header_classes %>" style="<%= grid_style %>">
      <% columns.each do |col| %><%= col.html_safe? ? col : tag.span(col, class: "truncate") %><% end %>
    </div>
  <% end %>
  <%# The stable container (append target) is a `peer`, rendered inline so it is truly :empty with no
      rows (no whitespace nodes); each row is a dom_id-keyed partial (replace target). %>
  <%= tag.div(row ? render(partial: row, collection: collection, as: row_as, locals: { template: grid_template }) : nil,
              id:, class: class_names(rows_classes, "peer")) %>
  <% if empty? %>
    <div class="hidden peer-empty:block"><%= empty %></div>
  <% end %>
</div>
