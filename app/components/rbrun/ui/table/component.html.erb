<div class="<%= class_names(wrapper_classes, @attrs.delete(:class)) %>" <%= tag.attributes(@attrs) %>>
  <%# flush: header sticks to the top of the scroll region so it stays while rows scroll. %>
  <% unless headless? %>
    <div class="grid items-center gap-4 border-b border-slate-200 bg-slate-50 px-6 py-3 text-xs font-medium uppercase tracking-wider text-slate-500 <%= "sticky top-0 z-10" if @flush %>" style="<%= grid_style %>">
      <% @columns.each do |col| %><%= col.html_safe? ? col : tag.span(col, class: "truncate") %><% end %>
    </div>
  <% end %>
  <div class="<%= rows_classes %>">
    <% rows.each do |row| %>
      <div class="grid items-center gap-4 px-6 py-4 transition-colors hover:bg-slate-50" style="<%= grid_style %>"><%= row %></div>
    <% end %>
  </div>
</div>
