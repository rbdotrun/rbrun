<%# The repo switcher dialog. Renders THROUGH Ui::Surface (dialog chrome) so the title + search box sit
    in the STATIC surface area — the header and a fixed strip below it — while ONLY the repo list scrolls
    in the body. The `command` controller wraps the whole surface (display:contents keeps the flex height
    chain unbroken); the search input (fixed strip) repoints the lazy #repo_results frame (body) at the
    server-side GitHub search. No GitHub call builds this shell — the lazy frame fires its own request
    (recent repos on open, search on typing). %>
<turbo-frame id="modal">
  <div class="contents" data-controller="command" data-command-url-value="<%= rbrun.repos_path %>">
    <%= component("surface", preset: :dialog, elevation: :lg, size: :md,
                  title: "Switch repository", inset: :flush, css: "w-[34rem] max-w-full") do |s| %>
      <% s.with_fixed_area do %>
        <div class="p-3">
          <%= component("input", name: "q", placeholder: "Search repositories…", autocomplete: "off",
                        data: { command_target: "input", action: "input->command#search" }) %>
        </div>
      <% end %>
      <% s.with_body do %>
        <%= turbo_frame_tag "repo_results", src: rbrun.repos_path, loading: :lazy,
                            data: { command_target: "frame" } do %>
          <%= component("skeleton", variant: :list_item, rows: 6) %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</turbo-frame>
