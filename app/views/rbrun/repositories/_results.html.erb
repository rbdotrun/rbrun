<%# The repo rows — a menu whose links each POST to switch_repo (turbo), the current repo checked.
    Rendered inside the #repo_results Turbo frame. Locals: repos ([GithubRepos::Repo]), current (str). %>
<% if repos.any? %>
  <%= component("menu") do |m| %>
    <% repos.each do |repo| %>
      <% m.link repo.full_name, href: rbrun.switch_repo_path(repo: repo.full_name, base: repo.default_branch),
                avatar: repo.full_name.split("/").last.to_s[0, 2].upcase,
                active: (repo.full_name == current),
                data: { turbo_method: :post } %>
    <% end %>
  <% end %>
<% else %>
  <p class="px-3 py-6 text-center text-sm text-slate-400">No repositories found.</p>
<% end %>
