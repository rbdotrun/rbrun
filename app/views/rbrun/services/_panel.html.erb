<%# The worktree Services panel (sidebar, under the repo switcher). Rendered from DB rows only — no %>
<%# sandbox calls — so it is safe to broadcast. Its own target = #services_panel_<worktree.id>. %>
<div id="services_panel_<%= worktree.id %>">
  <% runs = worktree.service_runs.order(:name).to_a %>
  <% saved = Rbrun::RepoService.for_tenant(worktree.tenant).for_repo(worktree.repo) %>
  <% exposures = worktree.service_exposures.index_by(&:name) %>
  <% if runs.any? || saved.any? %>
    <div class="rounded-md border border-slate-200 bg-white group-data-[collapsed]/sidebar:hidden">
      <div class="flex items-center gap-2 border-b border-slate-100 px-2.5 py-1.5">
        <%= lucide_icon("server", class: "size-3.5 text-slate-400") %>
        <span class="text-xs font-medium uppercase tracking-wide text-slate-400">Services</span>
      </div>
      <% if runs.any? %>
        <ul class="flex flex-col">
          <% runs.each do |run| %>
            <li class="flex items-center gap-2 px-2.5 py-1.5 text-sm">
              <span class="size-2 shrink-0 rounded-full <%= run.status_running? ? "bg-green-500" : (run.status_exited? ? "bg-red-400" : "bg-slate-300") %>"
                    title="<%= run.status %>"></span>
              <span class="truncate font-medium text-slate-700"><%= run.name %></span>
              <% if run.port.present? %><span class="text-xs text-slate-400">:<%= run.port %></span><% end %>
              <span class="ml-auto flex items-center gap-1">
                <%# Previewing is a SEPARATE decision from running: Open only appears once the service is %>
                <%# actually previewed. A port alone means it merely CAN be previewed. %>
                <% exp = exposures[run.name] %>
                <% if exp&.previewed? && run.url.present? %>
                  <%= link_to exp.preview_url, target: "_blank", rel: "noopener",
                        class: "rounded p-1 text-green-600 hover:bg-slate-100", title: "Open preview" do %>
                    <%= lucide_icon("external-link", class: "size-3.5") %>
                  <% end %>
                  <%# Level 3 — only offered once previewed. Public state is shown loudly, never quietly. %>
                  <% if exp.shared_public? %>
                    <%= button_to rbrun.stop_sharing_service_path(run), method: :post,
                          class: "rounded p-1 text-amber-600 hover:bg-amber-50", title: "Public — anyone with the link. Click to stop sharing." do %>
                      <%= lucide_icon("globe", class: "size-3.5") %>
                    <% end %>
                  <% else %>
                    <%= button_to rbrun.share_public_service_path(run), method: :post,
                          class: "rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600", title: "Share publicly (anyone with the link)" do %>
                      <%= lucide_icon("globe", class: "size-3.5") %>
                    <% end %>
                  <% end %>
                  <%= button_to rbrun.stop_preview_service_path(run), method: :post,
                        class: "rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600", title: "Stop previewing" do %>
                    <%= lucide_icon("eye-off", class: "size-3.5") %>
                  <% end %>
                <% elsif run.port.present? %>
                  <%= button_to rbrun.preview_service_path(run), method: :post,
                        class: "rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600", title: "Preview this service" do %>
                    <%= lucide_icon("eye", class: "size-3.5") %>
                  <% end %>
                <% end %>
                <%= button_to rbrun.logs_service_path(run), method: :get,
                      class: "rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600", title: "Logs", form: { data: { turbo_stream: true } } do %>
                  <%= lucide_icon("scroll-text", class: "size-3.5") %>
                <% end %>
                <%= button_to rbrun.restart_service_path(run), method: :post,
                      class: "rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600", title: "Restart" do %>
                  <%= lucide_icon("rotate-cw", class: "size-3.5") %>
                <% end %>
                <%= button_to rbrun.stop_service_path(run), method: :post,
                      class: "rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600", title: "Stop" do %>
                  <%= lucide_icon("square", class: "size-3.5") %>
                <% end %>
              </span>
            </li>
          <% end %>
        </ul>
      <% elsif saved.any? %>
        <div class="px-2.5 py-2">
          <%= button_to "Restart all", rbrun.restart_all_services_path(worktree_id: worktree.id), method: :post,
                class: "w-full rounded-md border border-slate-200 px-2 py-1 text-xs font-medium text-slate-600 hover:bg-slate-50" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
