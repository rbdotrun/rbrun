<% session = local_assigns[:session] %>
<% working = local_assigns.fetch(:working, false) %>

<% if session&.failed? %>
  <div class="mb-2 flex items-center justify-between gap-2 rounded-lg border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-700">
    <span>⚠ The turn failed — the conversation is intact. Resume where it stopped.</span>
    <%= button_to "Retry", rbrun.session_retry_path(session), method: :post,
          class: "flex-shrink-0 rounded-md bg-red-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-red-500 cursor-pointer" %>
  </div>
<% end %>

<%= form_with(url: rbrun.session_message_path(session), id: "new_message", data: { controller: "composer" },
      class: "flex flex-col gap-1.5 rounded-xl border border-slate-300 bg-white px-3 py-2 shadow-xs transition-colors focus-within:border-default-500 focus-within:ring-1 focus-within:ring-default-500") do |form| %>
  <%= form.text_area :content, name: "message[content]", rows: 1, disabled: working, autofocus: !working, autocomplete: "off",
        placeholder: working ? "The agent is working…" : "Write your request…",
        data: { composer_target: "input", action: "input->composer#input keydown->composer#keydown" },
        class: "max-h-[200px] w-full resize-none bg-transparent text-sm leading-relaxed text-slate-800 placeholder:text-slate-400 focus:outline-none disabled:text-slate-400" %>

  <div class="flex items-center justify-end">
    <% if working %>
      <span class="flex size-8 items-center justify-center rounded-full bg-slate-100 text-slate-400" aria-label="The agent is working">
        <%= render(Rbrun::Ui::Spinner::Component.new(size: :sm)) %>
      </span>
    <% else %>
      <button type="submit" data-composer-target="send" disabled aria-label="Send"
              class="flex size-8 items-center justify-center rounded-full bg-default-600 text-white transition-colors hover:bg-default-600/90 disabled:cursor-not-allowed disabled:opacity-40">
        <%= lucide_icon("arrow-up", class: "size-4") %>
      </button>
    <% end %>
  </div>
<% end %>
