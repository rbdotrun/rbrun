<%# The skills list — the table primitive in its streamable form: a collection of dom_id-keyed rows in
    a stable container (Skill::ROWS_ID). Skill#broadcast_row appends/replaces single rows into it. The
    empty slot shows only while the container has no rows (auto-hides on the first streamed row). %>
<%= component("table", columns: ["Name", "Slug", "Version", "Source"],
              template: Rbrun::Skill::TABLE_TEMPLATE, id: Rbrun::Skill::ROWS_ID,
              collection: skills, row: "rbrun/skills/skill_row", row_as: :skill) do |t| %>
  <% t.with_empty do %>
    <%= component("empty", title: "No skills yet",
                  subtitle: "Build one with the assistant, or add a c.skill / c.skills_path folder and reseed.") do |e| %>
      <% e.with_cta do %>
        <%= form_with url: rbrun.build_skill_path, method: :post, data: { turbo_frame: "drawer" } do %>
          <%= component("button", variant: :primary, size: :sm, type: "submit") do %>
            <%= lucide_icon("plus", class: "size-4") %> New skill
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
