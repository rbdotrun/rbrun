<%# The skills list as the table primitive. Extracted so the promote broadcast can replace #skills_table. %>
<% if rows.empty? %>
  <p class="text-sm text-slate-400">No skills yet. Click <strong>New skill</strong> to build one with the assistant, or add a <code>c.skill</code> / <code>c.skills_path</code> folder and reseed.</p>
<% else %>
  <%= component("table", columns: ["Name", "Slug", "Version", "Source", "Status"],
                template: "minmax(0,2fr) minmax(0,1.5fr) minmax(0,1fr) minmax(0,1fr) minmax(0,1fr)") do |t| %>
    <% rows.each do |r| %>
      <% skill = r[:skill] %>
      <% t.with_row do %>
        <span class="truncate font-medium text-slate-800"><%= skill.name %></span>
        <span class="truncate font-mono text-xs text-slate-500"><%= skill.slug %></span>
        <span class="truncate text-xs text-slate-500"><%= skill.current_version ? "v#{skill.current_version.digest[0, 7]}" : "—" %></span>
        <span class="truncate text-xs text-slate-500"><%= skill.current_version&.source || "—" %></span>
        <span>
          <%= component("badge", label: r[:state].to_s, color: (r[:state] == :clean ? :slate : :amber)) %>
        </span>
      <% end %>
    <% end %>
  <% end %>
<% end %>
