<%= component("surface", title: "Skills", heading: :h1, inset: :centered) do |s| %>
  <% s.with_actions do %>
    <%= form_with url: rbrun.build_skill_path, method: :post, data: { turbo_frame: "drawer" } do %>
      <%= component("button", variant: :primary, size: :sm, type: "submit") do %>
        <%= lucide_icon("plus", class: "size-4") %> New skill
      <% end %>
    <% end %>
  <% end %>

  <% s.with_body do %>
    <%= turbo_stream_from ["rbrun", current_tenant, "skills"] %>

    <p class="mb-4 text-sm text-slate-500">Capabilities the agent stages from the store. Build one with the assistant, or author from config — the store is the source of truth.</p>

    <div id="skills_table">
      <%= render "rbrun/skills/table", skills: @skills %>
    </div>

    <%# Divergence lives here, glued in the view: ask each skill its reconcile status against its
        authored config source, and render the diff + reconcile for the ones that need attention. %>
    <% attention = @skills.select { |skill| skill.reconcile_status(@authored[skill.slug]&.dig(:files)) != :clean } %>
    <% if attention.any? %>
      <h2 class="mt-8 mb-3 text-sm font-semibold text-amber-700">Needs attention</h2>
      <div class="flex flex-col gap-3">
        <% attention.each do |skill| %>
          <% authored = @authored[skill.slug] %>
          <% status = skill.reconcile_status(authored&.dig(:files)) %>
          <div class="rounded-lg border border-amber-300 bg-amber-50 p-4">
            <p class="font-medium text-slate-800"><%= skill.name %> <span class="text-xs font-normal text-slate-400"><%= skill.slug %></span></p>
            <% if status == :diverged %>
              <% current_md = skill.current_version && Rbrun::SkillArchive.files(skill.current_version.archive)["SKILL.md"] %>
              <p class="mt-2 mb-1 text-xs font-medium text-amber-700">The authored source differs from the stored version.</p>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <div>
                  <p class="mb-1 text-slate-500">Stored (current)</p>
                  <pre class="overflow-x-auto rounded border border-slate-200 bg-white p-2 text-[11px] leading-relaxed text-slate-600"><%= current_md %></pre>
                </div>
                <div>
                  <p class="mb-1 text-slate-500">Authored (source)</p>
                  <pre class="overflow-x-auto rounded border border-slate-200 bg-white p-2 text-[11px] leading-relaxed text-slate-600"><%= authored[:files]["SKILL.md"] %></pre>
                </div>
              </div>
              <div class="mt-3 flex items-center gap-2">
                <%= button_to "Reload", rbrun.reconcile_skill_path(skill.slug, decision: "reload"), method: :post,
                      class: "rounded-md bg-default-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-default-500 cursor-pointer" %>
                <%= button_to "Keep stored", rbrun.reconcile_skill_path(skill.slug, decision: "keep"), method: :post,
                      class: "rounded-md px-3 py-1.5 text-xs font-medium text-slate-700 ring-1 ring-inset ring-slate-300 hover:bg-slate-50 cursor-pointer" %>
              </div>
            <% else %>
              <p class="mt-2 text-xs font-medium text-amber-700">The authored source can't be read (missing or broken <code>SKILL.md</code>). Fix the source, then reseed.</p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
