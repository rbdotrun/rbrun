<!DOCTYPE html>
<html>
<head>
  <title>rbrun</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= stylesheet_link_tag "rbrun/rbrun", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "rbrun/rbrun", type: "module", "data-turbo-track": "reload" %>
</head>
<body class="h-screen bg-white text-slate-900">
  <div class="flex h-full flex-col">
    <header class="flex flex-shrink-0 items-center justify-between border-b border-slate-200 px-4 py-2">
      <%= link_to "rbrun", rbrun.sessions_path, class: "font-semibold" %>
      <div class="flex items-center gap-3 text-sm text-slate-500">
        <span><%= current_user&.email %></span>
        <%= button_to "Sign out", rbrun.logout_path, method: :delete, class: "hover:text-slate-700" %>
      </div>
    </header>
    <main class="min-h-0 flex-1"><%= yield %></main>
  </div>
</body>
</html>
