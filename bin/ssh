#!/usr/bin/env bash
#
# bin/ssh — jump onto the rbrun dev box (IP resolved live from Hetzner). No args: an interactive shell.
#   bin/ssh claude      -> straight into a Claude Code session on the box
#   bin/ssh <command…>  -> run a command on the box
#
# Uses your own ~/.ssh/id_rsa (same key bin/dev provisions the box with).

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
[[ -f .env ]] && { set -a; source .env; set +a; }
: "${HETZNER_API_TOKEN:?required — Hetzner Cloud API token (in .env)}"
export HCLOUD_TOKEN="$HETZNER_API_TOKEN"

KEY="${RBRUN_SSH_KEY_FILE:-$HOME/.ssh/id_rsa}"
NAME="${RBRUN_SERVER_NAME:-rbrun-dev}"
REMOTE_DIR="/root/rbrun"
IP="$(hcloud server ip "$NAME" 2>/dev/null)" || true
[[ -n "${IP:-}" ]] || { echo "no '$NAME' box — run bin/dev first" >&2; exit 1; }

OPTS=(-t -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -i "$KEY")
if [[ "${1:-}" == "claude" ]]; then
  exec ssh "${OPTS[@]}" "root@$IP" \
    "cd $REMOTE_DIR && export CLAUDE_CODE_OAUTH_TOKEN=\$(grep ^ANTHROPIC_OAUTH_TOKEN= .env | cut -d= -f2-) && exec \$HOME/.local/bin/claude"
elif [[ $# -gt 0 ]]; then
  exec ssh "${OPTS[@]}" "root@$IP" "$@"
else
  exec ssh "${OPTS[@]}" "root@$IP"
fi
