#!/usr/bin/env bash
#
# bin/destroy — tear down the rbrun dev box and its DNS record. Nothing else. Idempotent: each step is a
# find-then-delete, so a missing record or server is a no-op and re-running is safe.
#
# Required env (.env at repo root is auto-sourced): HETZNER_API_TOKEN, CLOUDFLARE_API_KEY, CLOUDFLARE_ZONE_ID.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT"
log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m!! %s\033[0m\n' "$*" >&2; exit 1; }

SERVER_NAME="${RBRUN_SERVER_NAME:-rbrun-dev}"
APP_HOST="${RBRUN_APP_HOST:-dev.rb.run}"

ENV_FILE="${ENV_FILE:-$ROOT/.env}"
[[ -f "$ENV_FILE" ]] && { log "sourcing $ENV_FILE"; set -a; source "$ENV_FILE"; set +a; }
for c in hcloud ruby; do command -v "$c" >/dev/null || fail "missing binary: $c"; done
: "${HETZNER_API_TOKEN:?required}"; : "${CLOUDFLARE_API_KEY:?required}"; : "${CLOUDFLARE_ZONE_ID:?required}"
export HCLOUD_TOKEN="$HETZNER_API_TOKEN"

# 1. DNS record (find-then-delete).
log "DNS: removing $APP_HOST"
CF_HOST="$APP_HOST" ruby <<'RUBY' || fail "DNS delete failed"
require "net/http"; require "json"; require "uri"
tok = ENV.fetch("CLOUDFLARE_API_KEY"); zone = ENV.fetch("CLOUDFLARE_ZONE_ID"); host = ENV.fetch("CF_HOST")
base = "https://api.cloudflare.com/client/v4/zones/#{zone}/dns_records"
def cf(m, url, tok)
  uri = URI(url); k = { get: Net::HTTP::Get, delete: Net::HTTP::Delete }.fetch(m)
  r = k.new(uri); r["Authorization"] = "Bearer #{tok}"
  res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(r) }
  j = JSON.parse(res.body) rescue {}
  abort "cloudflare #{m}: #{Array(j["errors"]).map { |e| e["message"] }.join("; ")}" unless j["success"]
  j["result"]
end
rec = Array(cf(:get, "#{base}?name=#{host}", tok)).first
if rec
  cf(:delete, "#{base}/#{rec["id"]}", tok); puts "  deleted #{host}"
else
  puts "  no record for #{host} (already gone)"
end
RUBY

# 2. Server (find-then-delete).
if hcloud server describe "$SERVER_NAME" >/dev/null 2>&1; then
  log "server: deleting '$SERVER_NAME'"
  hcloud server delete "$SERVER_NAME" >/dev/null
  log "  deleted"
else
  log "server: '$SERVER_NAME' already gone"
fi

log "done"
