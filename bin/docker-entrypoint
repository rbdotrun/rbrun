#!/bin/bash -e
#
# Prepare the database the first time the server boots (idempotent: db:prepare loads the schema when the
# DB is empty, applies pending migrations otherwise, and no-ops when already current). Only runs for the
# server command so one-off `kamal app exec` invocations don't re-migrate.

if [ "${1}" = "./bin/rails" ] && [ "${2}" = "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
