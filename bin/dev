#!/usr/bin/env bash
#
# bin/dev — bring up a remote Hetzner box as a Claude Code dev host for rbrun, idempotently, then drop into
# a live Claude Code session ON the box. Runs the FULL pass every time (slow but always convergent, by
# design): provision -> DNS -> remote tooling -> repo -> secrets -> app + tunnel -> validate claude -> ssh
# in + claude session. Re-running re-syncs everything and reconnects.
#
# Serving: Caddy on the box terminates TLS on demand (per-host Let's Encrypt) and reverse-proxies to the
# app on :3000, so dev.rb.run and every <token>-preview.rb.run serve HTTPS with NO tunnel in the app path.
# The cloudflared tunnel is kept for Daytona webhooks only.
#
# Auth: your own ~/.ssh/id_rsa for the box; `gh auth token` for the private clone; CLAUDE_CODE_OAUTH_TOKEN
# (= ANTHROPIC_OAUTH_TOKEN from .env) for Claude Code.
#
# Required env (.env at repo root is auto-sourced): HETZNER_API_TOKEN, ANTHROPIC_OAUTH_TOKEN,
# CLOUDFLARE_API_KEY, CLOUDFLARE_ZONE_ID (DAYTONA_API_KEY etc. flow through to the app via .env).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$ROOT"
log()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m!! %s\033[0m\n' "$*" >&2; exit 1; }

SERVER_NAME="${RBRUN_SERVER_NAME:-rbrun-dev}"
SERVER_TYPE="${RBRUN_SERVER_TYPE:-cx23}"
SERVER_IMAGE="${RBRUN_SERVER_IMAGE:-ubuntu-24.04}"
SERVER_LOCATION="${RBRUN_SERVER_LOCATION:-fsn1}"
SSH_KEY_FILE="${RBRUN_SSH_KEY_FILE:-$HOME/.ssh/id_rsa}"
SSH_KEY_NAME="${RBRUN_SSH_KEY_NAME:-rbrun-ben}"
APP_HOST="${RBRUN_APP_HOST:-dev.rb.run}"
TUNNEL_HOST="${RBRUN_TUNNEL_HOST:-rbrun-dev.rb.run}"
REMOTE_DIR="/root/rbrun"
RUBY_VERSION="3.4.4"

# --- 1. env + preconditions ---------------------------------------------
ENV_FILE="${ENV_FILE:-$ROOT/.env}"
[[ -f "$ENV_FILE" ]] && { log "sourcing $ENV_FILE"; set -a; source "$ENV_FILE"; set +a; }
for c in hcloud gh ssh scp ssh-keygen ruby curl; do command -v "$c" >/dev/null || fail "missing binary: $c"; done
[[ -f "$SSH_KEY_FILE" ]]      || fail "ssh key not found: $SSH_KEY_FILE"
[[ -f "${SSH_KEY_FILE}.pub" ]] || fail "ssh pubkey not found: ${SSH_KEY_FILE}.pub"
: "${HETZNER_API_TOKEN:?required — Hetzner Cloud API token}"
: "${ANTHROPIC_OAUTH_TOKEN:?required — Claude Code token}"
: "${CLOUDFLARE_API_KEY:?required — Cloudflare token (Zone:DNS:Edit + Zone:Read)}"
: "${CLOUDFLARE_ZONE_ID:?required — Cloudflare zone id}"
export HCLOUD_TOKEN="$HETZNER_API_TOKEN"
GH_TOKEN_VAL="$(gh auth token)" || fail "gh auth token failed — run: gh auth login"
GIT_NAME="$(git config user.name 2>/dev/null || true)"    # mirror your local identity onto the box
GIT_EMAIL="$(git config user.email 2>/dev/null || true)"

# The box IP is ephemeral (Hetzner recycles it), so a reused IP carries a stale known_hosts key that
# accept-new would refuse. Skip known_hosts for it entirely — this is a throwaway dev box we own.
SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -i "$SSH_KEY_FILE")
rexec() { ssh "${SSH_OPTS[@]}" "root@$SERVER_IP" "$@"; }

# --- 2. ssh key + box (find-or-create) ----------------------------------
if ! hcloud ssh-key describe "$SSH_KEY_NAME" >/dev/null 2>&1; then
  log "registering ssh key '$SSH_KEY_NAME' (from ${SSH_KEY_FILE}.pub)"
  hcloud ssh-key create --name "$SSH_KEY_NAME" --public-key-from-file "${SSH_KEY_FILE}.pub" >/dev/null 2>&1 \
    || log "ssh key fingerprint already present — continuing"
fi
if hcloud server describe "$SERVER_NAME" >/dev/null 2>&1; then
  log "server '$SERVER_NAME' exists — reusing"
else
  log "creating server '$SERVER_NAME' ($SERVER_TYPE / $SERVER_IMAGE / $SERVER_LOCATION)"
  hcloud server create --name "$SERVER_NAME" --type "$SERVER_TYPE" --image "$SERVER_IMAGE" \
    --location "$SERVER_LOCATION" --ssh-key "$SSH_KEY_NAME" >/dev/null
fi
SERVER_IP="$(hcloud server ip "$SERVER_NAME")"; [[ -n "$SERVER_IP" ]] || fail "no IP for '$SERVER_NAME'"
log "server IP: $SERVER_IP"

# --- 3. wait for SSH ----------------------------------------------------
log "waiting for SSH on $SERVER_IP"
for i in $(seq 1 60); do rexec true 2>/dev/null && { log "SSH up"; break; }; [[ $i -eq 60 ]] && fail "no SSH"; sleep 5; done

# --- 4. DNS: dev.rb.run A -> IP (grey; Caddy terminates TLS on the box) --
log "DNS: $APP_HOST A -> $SERVER_IP (proxied=false)"
CF_HOST="$APP_HOST" CF_IP="$SERVER_IP" ruby <<'RUBY' || fail "DNS upsert failed"
require "net/http"; require "json"; require "uri"
tok  = ENV.fetch("CLOUDFLARE_API_KEY"); zone = ENV.fetch("CLOUDFLARE_ZONE_ID")
host = ENV.fetch("CF_HOST");            ip   = ENV.fetch("CF_IP")
base = "https://api.cloudflare.com/client/v4/zones/#{zone}/dns_records"
def cf(m, url, tok, body = nil)
  uri = URI(url); k = { get: Net::HTTP::Get, post: Net::HTTP::Post, put: Net::HTTP::Put }.fetch(m)
  r = k.new(uri); r["Authorization"] = "Bearer #{tok}"; r["Content-Type"] = "application/json"
  r.body = JSON.generate(body) if body
  res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(r) }
  j = JSON.parse(res.body) rescue {}
  abort "cloudflare #{m}: #{Array(j["errors"]).map { |e| e["message"] }.join("; ")}" unless j["success"]
  j["result"]
end
rec = Array(cf(:get, "#{base}?name=#{host}", tok)).first
d   = { type: "A", name: host, content: ip, proxied: false, ttl: 120 }
rec ? cf(:put, "#{base}/#{rec["id"]}", tok, d) : cf(:post, base, tok, d)
puts "  #{host} -> #{ip}"
RUBY

# --- 5. remote tooling (idempotent) -------------------------------------
log "remote: tooling (apt, mise+ruby $RUBY_VERSION, caddy, cloudflared, claude code)"
rexec "RUBY_VERSION='$RUBY_VERSION' bash -s" <<'REMOTE'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
# build-essential + Ruby's build deps: with libssl-dev/zlib/readline/ffi present, ruby-build links the
# system libraries instead of fragile source-compiling its own OpenSSL (which fails on a bare box).
apt-get install -y -qq git curl build-essential pkg-config ca-certificates gnupg \
  debian-keyring debian-archive-keyring apt-transport-https \
  libssl-dev zlib1g-dev libyaml-dev libreadline-dev libffi-dev libgdbm-dev libncurses-dev libsqlite3-dev uuid-dev autoconf >/dev/null

# mise + ruby (idempotent)
[ -x "$HOME/.local/bin/mise" ] || curl -fsSL https://mise.run | sh
export PATH="$HOME/.local/bin:$PATH"
grep -q 'mise activate' ~/.bashrc 2>/dev/null || echo 'eval "$($HOME/.local/bin/mise activate bash)"' >> ~/.bashrc
mise use -g "ruby@${RUBY_VERSION}" >/dev/null
eval "$($HOME/.local/bin/mise activate bash)"; mise exec -- ruby -v

# caddy (idempotent)
if ! command -v caddy >/dev/null; then
  curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
  curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' > /etc/apt/sources.list.d/caddy-stable.list
  apt-get update -qq && apt-get install -y -qq caddy >/dev/null
fi

# cloudflared (idempotent)
if ! command -v cloudflared >/dev/null; then
  curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb -o /tmp/cf.deb
  dpkg -i /tmp/cf.deb >/dev/null
fi

# claude code (idempotent)
[ -x "$HOME/.local/bin/claude" ] || command -v claude >/dev/null || curl -fsSL https://claude.ai/install.sh | bash
echo "tooling ok"
REMOTE

# --- 6. repo clone/pull (private, via a short-lived gh token) -----------
log "remote: clone/update repo -> $REMOTE_DIR"
rexec "GH_TOKEN='$GH_TOKEN_VAL' REMOTE_DIR='$REMOTE_DIR' bash -s" <<'REMOTE'
set -euo pipefail
URL="https://x-access-token:${GH_TOKEN}@github.com/rbdotrun/rbrun.git"
if [ -d "$REMOTE_DIR/.git" ]; then
  git -C "$REMOTE_DIR" remote set-url origin "$URL"
  git -C "$REMOTE_DIR" fetch --quiet origin main && git -C "$REMOTE_DIR" reset --hard --quiet origin/main
else
  git clone --quiet "$URL" "$REMOTE_DIR"
fi
git -C "$REMOTE_DIR" remote set-url origin "https://github.com/rbdotrun/rbrun.git"  # scrub the token from .git/config
echo "repo synced"
REMOTE

# --- 6b. git identity + push credential on the box (idempotent) ---------
# So a Claude Code session on the box can commit + push as you, without prompting. Identity mirrors your
# local git; the push credential is the gh token stored in the standard credential-store file.
log "remote: git identity + push credential"
rexec "GH_TOKEN='$GH_TOKEN_VAL' GIT_NAME='$GIT_NAME' GIT_EMAIL='$GIT_EMAIL' bash -s" <<'REMOTE'
set -euo pipefail
[ -n "${GIT_NAME:-}" ]  && git config --global user.name  "$GIT_NAME"
[ -n "${GIT_EMAIL:-}" ] && git config --global user.email "$GIT_EMAIL"
git config --global credential.helper store
umask 077; printf 'https://x-access-token:%s@github.com\n' "$GH_TOKEN" > ~/.git-credentials
echo "git: $(git config --global user.name) <$(git config --global user.email)>"
REMOTE

# --- 7. secrets: sync .env + derive CLAUDE_CODE_OAUTH_TOKEN --------------
log "remote: sync .env + claude token"
scp "${SSH_OPTS[@]}" "$ENV_FILE" "root@$SERVER_IP:$REMOTE_DIR/.env" >/dev/null
rexec "REMOTE_DIR='$REMOTE_DIR' bash -s" <<'REMOTE'
set -euo pipefail
cd "$REMOTE_DIR"
tok="$(grep '^ANTHROPIC_OAUTH_TOKEN=' .env | tail -1 | cut -d= -f2-)"
grep -q '^CLAUDE_CODE_OAUTH_TOKEN=' .env && sed -i "s#^CLAUDE_CODE_OAUTH_TOKEN=.*#CLAUDE_CODE_OAUTH_TOKEN=${tok}#" .env || echo "CLAUDE_CODE_OAUTH_TOKEN=${tok}" >> .env
# Persist the Claude token into EVERY login shell so `claude` is authed whether you land here via
# `bin/dev`, `bin/ssh claude`, or a plain `bin/ssh` + `claude`. Without this, only the specific launch
# command carried the token and a plain shell would prompt to log in.
umask 077; printf 'export CLAUDE_CODE_OAUTH_TOKEN=%s\n' "$tok" > /etc/profile.d/rbrun-claude.sh
chmod 644 /etc/profile.d/rbrun-claude.sh
echo "secrets synced"
REMOTE

# --- 8. app deps + database ---------------------------------------------
log "remote: bundle install + db:prepare (development)"
# rbrun is an engine: the dummy host app's own rake tasks are namespaced under app:, so it's app:db:prepare
# (same reason CLAUDE.md uses app:dogfood:*). db:prepare is idempotent — load schema if empty, else migrate.
rexec "bash -lc 'eval \"\$(\$HOME/.local/bin/mise activate bash)\"; cd $REMOTE_DIR; set -a; source .env; set +a; export RAILS_ENV=development; mise exec -- bundle install --quiet && mise exec -- bin/rails app:db:prepare'"

# --- 9. app + Caddy + webhook tunnel (idempotent services) --------------
log "remote: caddy (on-demand TLS) + app service + webhook tunnel"
rexec "APP_HOST='$APP_HOST' TUNNEL_HOST='$TUNNEL_HOST' REMOTE_DIR='$REMOTE_DIR' bash -s" <<'REMOTE'
set -euo pipefail
MISE="$HOME/.local/bin/mise"

# App service (puma on :3000, development).
cat >/etc/systemd/system/rbrun-app.service <<UNIT
[Unit]
Description=rbrun dummy app (dev)
After=network.target
[Service]
WorkingDirectory=${REMOTE_DIR}
EnvironmentFile=${REMOTE_DIR}/.env
Environment=RAILS_ENV=development
Environment=PORT=3000
ExecStart=${MISE} exec -- bin/rails server -b 127.0.0.1 -p 3000
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
UNIT
systemctl daemon-reload
systemctl enable --now rbrun-app.service >/dev/null 2>&1 || true
systemctl restart rbrun-app.service

# Caddy: on-demand TLS for any rb.run host that resolves here -> the app. The ask endpoint (the app's /up)
# gates issuance so only hosts the app answers get a cert.
cat >/etc/caddy/Caddyfile <<'CADDY'
{
	on_demand_tls {
		ask http://127.0.0.1:3000/up
	}
}

https:// {
	tls {
		on_demand
	}
	reverse_proxy 127.0.0.1:3000
}
CADDY
systemctl reload caddy 2>/dev/null || systemctl restart caddy

# Webhook tunnel (Daytona -> box): bin/setup upserts the tunnel + emits TUNNEL_TOKEN; install cloudflared
# as a service. This is webhooks-only and never serves the app or previews.
cd "$REMOTE_DIR"
PORT=3000 RBRUN_TUNNEL_HOST="$TUNNEL_HOST" "$MISE" exec -- ruby bin/setup >/dev/null 2>&1 || true
TT="$(grep '^TUNNEL_TOKEN=' .env | tail -1 | cut -d= -f2-)"
if [ -n "$TT" ]; then cloudflared service install "$TT" >/dev/null 2>&1 || systemctl restart cloudflared 2>/dev/null || true; fi
echo "services up"
REMOTE

# --- 10. validate Claude Code, then open a session on the box -----------
log "remote: validate Claude Code"
rexec "bash -lc 'cd $REMOTE_DIR; export CLAUDE_CODE_OAUTH_TOKEN=\$(grep ^ANTHROPIC_OAUTH_TOKEN= .env | cut -d= -f2-); \$HOME/.local/bin/claude --version'" \
  || fail "Claude Code not working on the box"

log "ready — app at https://$APP_HOST  ·  opening a Claude Code session on $SERVER_IP"
echo
exec ssh -t "${SSH_OPTS[@]}" "root@$SERVER_IP" \
  "cd $REMOTE_DIR && export CLAUDE_CODE_OAUTH_TOKEN=\$(grep ^ANTHROPIC_OAUTH_TOKEN= .env | cut -d= -f2-) && exec \$HOME/.local/bin/claude"
