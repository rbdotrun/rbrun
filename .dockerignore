# Build context excludes. Keep the image lean and never ship secrets or local state.
.git
.gitignore
.env
.env.*
.deploy
.kamal/secrets

# Local runtime state — the DB lives on a persistent volume, not in the image.
test/dummy/storage/*
!test/dummy/storage/.keep
storage/*
test/dummy/tmp/*
tmp/*
log/*
test/dummy/log/*

# Node/asset toolchain — the engine ships a PREBUILT bundle (app/assets/builds), so bun never runs here.
node_modules

# Test + docs cruft not needed at runtime.
test/dummy/db/*.sqlite3
coverage
.rubocop.yml
